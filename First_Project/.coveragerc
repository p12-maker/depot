# 测试覆盖率配置
[run]
source = 
    main
    system_monitor
omit =
    */tests/*
    */test_*
    */__init__.py

[report]
show_missing = True
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if HAS_QT:
    @unittest.skipUnless

[html]
directory = htmlcov
